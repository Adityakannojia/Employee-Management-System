REFRESH_EXPIRE=7d

CORS_ORIGIN=http://localhost:5173

COOKIE_ACCESS_MAX_MS=3600000
COOKIE_REFRESH_MAX_MS=604800000

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL=300
