PORT=8000
NODE_ENV=development

MONGODB_URL=mongodb://localhost:27017
DB_NAME=employee_management

ACCESSTOKEN_SECRET=your_access_token_secret_min_32_characters
REFRESHTOKEN_SECRET=your_refresh_token_secret_min_32_characters
